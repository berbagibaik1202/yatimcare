# AI settings
# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App URL
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Backend database
# database_host=localhost
# database_port=3306
# database_user=root
# database_password=
# database_name=yatimcare
# database_url optional jika ingin format URL penuh

# Frontend API root
# Kosongkan jika frontend dan backend satu origin.
# Untuk deployment di subfolder atau domain berbeda, isi dengan URL backend misalnya:
# VITE_API_BASE_URL="https://yourdomain.com/api"
VITE_API_BASE_URL=""
